# rpi5
# Raspberry Pi 5

# Change settings:
sudo raspi-config

# Update firmware:
sudo rpi-update

# Update EEPROM bootloader:
sudo rpi-eeprom-update -a

# Kernel page size fix - add to /boot/firmware/config.txt:
kernel=kernel8.img

# Enable PCIe Gen 3 (faster NVMe) - add to /boot/firmware/config.txt:
dtparam=pciex1_gen=3

# Enable ssh before first boot:
touch /boot/ssh
